# =============================================================================
# DOCINTEL - Engineering Document Intelligence MCP Server
# Environment Configuration Template
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=docintel
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://docintel:docintel@localhost:5432/docintel
# For SQLite prototyping (no pgvector):
# DATABASE_URL=sqlite+aiosqlite:///./docintel.db

# -----------------------------------------------------------------------------
# Local Model Server (Ollama / vLLM - OpenAI-compatible endpoint)
# -----------------------------------------------------------------------------
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama  # Ollama accepts any key; vLLM may require a real key
LLM_MODEL=llama3.2:3b-instruct-q4_K_M
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Embedding Model (local sentence-transformers)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu  # or "cuda" / "mps" if available

# -----------------------------------------------------------------------------
# OCR Configuration
# -----------------------------------------------------------------------------
OCR_ENGINE=paddle  # "paddle" (primary) or "tesseract" (fallback)
PADDLE_USE_ANGLE_CLS=true
TESSERACT_CMD=/usr/bin/tesseract  # adjust for Windows: C:\\Program Files\\Tesseract-OCR\\tesseract.exe
OCR_LANG=en
OCR_CONFIDENCE_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Validation
# -----------------------------------------------------------------------------
VALIDATION_CONFIDENCE_THRESHOLD=0.6
DOCUMENT_NUMBER_REGEX=^[A-Z]{3}-[A-Z]-[A-Z]{2}-\\d{2}-\\d{3}$
CONTRACT_NUMBER=3500003752

# -----------------------------------------------------------------------------
# DOCON Connector
# -----------------------------------------------------------------------------
DOCON_MODE=mock  # "mock" for MVP; "rest" / "file_drop" for production
DOCON_API_URL=http://localhost:8080/docon
DOCON_API_KEY=
DOCON_DROP_PATH=/var/docon/inbox

# -----------------------------------------------------------------------------
# Offline Guard (host allowlist - comma-separated)
# -----------------------------------------------------------------------------
ALLOWED_HOSTS=localhost,127.0.0.1,::1,ollama,vllm,localhost.localdomain

# -----------------------------------------------------------------------------
# CORS / Frontend
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
REFERENCE_DATA_PATH=./data/reference
UPLOAD_TEMP_PATH=./tmp/uploads
CHUNK_SIZE=512
CHUNK_OVERLAP=50