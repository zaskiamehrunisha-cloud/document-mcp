# Database Configuration
DB_URL=postgresql+asyncpg://doccontrol:secure_password@localhost:5432/engineering_docs
DB_ECHO=false

# Ollama Configuration (Local LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_FALLBACK_MODEL=qwen2.5:7b-instruct-q4_K_M

# Embedding Model
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_CACHE_SIZE=1000

# Document Controller Integration
DOCON_API_URL=http://document-controller.internal:8080/api/v1/submissions
DOCON_API_KEY=your_docon_api_key_here
DOCON_TIMEOUT=30

# Web UI Configuration
START_WEB_UI=true
WEB_PORT=8000
WEB_HOST=0.0.0.0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# OCR Configuration
OCR_DPI=300
OCR_CONFIDENCE_THRESHOLD=0.75
OCR_LANG=en
OCR_USE_GPU=true
OCR_FALLBACK_DPI=150

# Chunking Configuration
PARENT_CHUNK_SIZE=1024
PARENT_CHUNK_OVERLAP=128
CHILD_CHUNK_SIZE=256
CHILD_CHUNK_OVERLAP=32

# Validation Configuration
VALIDATION_RULE_RELOAD_INTERVAL=300

# Security
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin Credentials (for review queue access)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$LJ3mH5q8Y9zX2wR4tU6vA8nB1cD3eF5gH7iJ9kL2mN4oP6qR8sT0u

# File Storage
UPLOAD_DIR=./data/uploads
PREVIEW_DIR=./data/previews
MAX_UPLOAD_SIZE_MB=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json